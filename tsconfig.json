{
    "extends": "@apify/tsconfig",
    "compilerOptions": {
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "ES2022",
        "outDir": "dist",
        "rootDir": "./src",
        "incremental": false,
        "noUnusedLocals": true, // Aktifkan agar kode lebih bersih
        "noUnusedParameters": true, // Aktifkan untuk mendeteksi param yang tidak terpakai
        "skipLibCheck": true,
        "lib": ["ESNext", "DOM"] // Tambahkan ESNext agar support fitur JS terbaru
    },
    "include": ["./src/**/*"]
}
